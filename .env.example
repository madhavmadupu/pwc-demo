# Vertex AI Vector Search (optional — falls back to in-memory rules)
VECTOR_SEARCH_ENDPOINT=
DEPLOYED_INDEX_ID=

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8080
STREAMLIT_SERVER_ADDRESS=0.0.0.0
